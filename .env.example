# ─── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Copia la connection string de tu proyecto Neon (Settings → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Genera un string aleatorio largo: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Super Admin seed (solo para el primer deploy) ─────────────────────────────
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=superadmin123
